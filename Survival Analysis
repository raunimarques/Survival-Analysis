# Criar layouts em grade se houver plots válidos
if(length(individual_plots) > 0) {
  
  # Carregar biblioteca necessária
  if(!require(gridExtra, quietly = TRUE)) {
    install.packages("gridExtra")
    library(gridExtra)
  }
  
  n_plots <- length(individual_plots)
  cat("Criando grid com", n_plots, "plots\n")
  
  # Determinar layout da grade baseado no número de plots
  if(n_plots == 1) {
    ncols <- 1; nrows <- 1
  } else if(n_plots <= 2) {
    ncols <- 2; nrows <- 1
  } else if(n_plots <= 4) {
    ncols <- 2; nrows <- 2
  } else if(n_plots <= 6) {
    ncols <- 3; nrows <- 2
  } else if(n_plots <= 9) {
    ncols <- 3; nrows <- 3
  } else if(n_plots <= 12) {
    ncols <- 4; nrows <- 3
  } else if(n_plots <= 16) {
    ncols <- 4; nrows <- 4
  } else {
    # Para muitos plots, criar múltiplas páginas
    ncols <- 4; nrows <- 4
  }
  
  # Função para criar uma página de grid
  create_grid_page <- function(plots_subset, page_num = 1) {
    tryCatch({
      # Extrair apenas os plots (não os objetos ggsurvplot completos)
      plot_objects <- lapply(plots_subset, function(x) x$plot)
      
      # Criar o grid
      grid_plot <- do.call(grid.arrange, c(plot_objects, ncol = ncols))
      
      return(grid_plot)
      
    }, error = function(e) {
      cat("Erro ao criar grid da página", page_num, ":", e$message, "\n")
      return(NULL)
    })
  }
  
  # Se há muitos plots, dividir em páginas
  plots_per_page <- ncols * nrows
  
  if(n_plots <= plots_per_page) {
    # Uma única página
    tryCatch({
      # Calcular dimensões
      plot_width <- ncols * 5 + 1
      plot_height <- nrows * 4 + 1
      
      # Criar grid
      svg(paste0(output_dir, "/KaplanMeier_Combined_Grid.svg"),
          width = plot_width, height = plot_height)
      
      grid_result <- create_grid_page(individual_plots)
      
      dev.off()
      
      cat("Grid combinado salvo com", n_plots, "plots em", ncols, "x", nrows, "layout\n")
      
    }, error = function(e) {
      cat("Erro ao salvar grid único:", e$message, "\n")
    })
    
  } else {
    # Múltiplas páginas
    n_pages <- ceiling(n_plots / plots_per_page)
    
    for(page in 1:n_pages) {
      tryCatch({
        start_idx <- (page - 1) * plots_per_page + 1
        end_idx <- min(page * plots_per_page, n_plots)
        
        plots_subset <- individual_plots[start_idx:end_idx]
        
        # Calcular dimensões
        current_plots <- length(plots_subset)
        current_rows <- ceiling(current_plots / ncols)
        plot_width <- ncols * 5 + 1
        plot_height <- current_rows * 4 + 1
        
        # Criar grid para esta página
        svg(paste0(output_dir, "/KaplanMeier_Combined_Grid_Page", page, ".svg"),
            width = plot_width, height = plot_height)
        
        grid_result <- create_grid_page(plots_subset, page)
        
        dev.off()
        
        cat("Grid página", page, "salvo com", current_plots, "plots\n")
        
      }, error = function(e) {
        cat("Erro ao salvar grid página", page, ":", e$message, "\n")
      })
    }
    
    cat("Total de", n_pages, "páginas de grid criadas\n")
  }
  
  # Criar também uma versão compacta com todos os plots (se não for muitos)
  if(n_plots <= 20) {
    tryCatch({
      # Layout mais compacto
      compact_ncols <- ifelse(n_plots <= 9, 3, ifelse(n_plots <= 16, 4, 5))
      compact_nrows <- ceiling(n_plots / compact_ncols)
      
      # Dimensões menores para versão compacta
      compact_width <- compact_ncols * 4
      compact_height <- compact_nrows * 3.5
      
      svg(paste0(output_dir, "/KaplanMeier_Combined_Compact.svg"),
          width = compact_width, height = compact_height)
      
      # Extrair plots e criar grid compacto
      compact_plots <- lapply(individual_plots, function(x) x$plot)
      compact_grid <- do.call(grid.arrange, c(compact_plots, ncol = compact_ncols))
      
      dev.off()
      
      cat("Versão compacta salva com", n_plots, "plots em", compact_ncols, "x", compact_nrows, "layout\n")
      
    }, error = function(e) {
      cat("Erro ao criar versão compacta:", e$message, "\n")
    })
  }
  
} else {
  cat("Nenhum plot válido para criar grid\n")
}

