# ================================
# 2️⃣ Ajustar nomes de colunas e remover duplicados
# ================================
colnames(exp) <- gsub("\\.bam.*", "", colnames(exp))   
colnames(exp) <- gsub("\\.", "-", colnames(exp))       
colnames(exp) <- gsub("01A.*", "01A", colnames(exp))

# Remover duplicados mantendo maior soma
exp <- exp %>%
  rowwise() %>%
  mutate(total = sum(c_across(-X), na.rm = TRUE)) %>%
  ungroup() %>%
  group_by(X) %>%
  slice_max(total, n = 1) %>%
  ungroup() %>%
  dplyr::select(-total)

# Salvar nomes dos genes e definir rownames
