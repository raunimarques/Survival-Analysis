# ================================
# 3️⃣ Ler dados clínicos
# ================================
clin <- read.table(
  "~/Paper miRNA/Figuras certas/sobrevida/TCGA-PDAC_mRNAsi-Stemness.txt",
  sep = "\t", dec = ".", header = TRUE, check.names = FALSE
)

# ================================
# 4️⃣ Alinhar IDs entre expressão e clínicos
# ================================
common_IDs <- intersect(clin$ID, colnames(exp))
cat("IDs comuns encontrados:", length(common_IDs), "\n")
