            "~/Paper miRNA/Figuras certas/sobrevida/BinaryGeneExpression_PDACmRNAsiSamples.txt",
            sep = "\t", dec = ".", row.names = TRUE, col.names = NA)

# ================================
# 6️⃣ Preparar dados clínicos para Cox
# ================================
