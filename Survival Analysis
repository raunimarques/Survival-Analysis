# ================================
# 5️⃣ Transpor e binarizar expressão
# ================================
gene.exp <- t(exp)
exp.bin <- as.data.frame(gene.exp)
for(i in 1:ncol(exp.bin)) {
  med <- median(exp.bin[, i], na.rm = TRUE)
  exp.bin[, i] <- ifelse(exp.bin[, i] > med, 1, 0)
}
colnames(exp.bin) <- colnames(gene.exp)

# Salvar binarizado
