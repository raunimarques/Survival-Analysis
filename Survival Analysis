clin$OS_time <- as.numeric(as.character(clin$OS_time))
clin.os <- clin[, c("ID", "OS_time", "OS")]
clin.os <- clin.os[complete.cases(clin.os), ]

cat("Amostras com dados clínicos completos:", nrow(clin.os), "\n")

# ================================
# 7️⃣ Análise Cox univariada (CORRIGIDO)
# ================================
final.cox <- merge(clin.os, exp.bin, by.x = "ID", by.y = "row.names")
rownames(final.cox) <- final.cox$ID
final.cox <- final.cox[, -1]

# Função Cox segura (MELHORADA)
safe_cox <- function(covariate, data) {
  tryCatch({
    # Verificar se há variação no covariate
    if(length(unique(data[[covariate]])) < 2) {
      return(c(beta=NA, HR=NA, lower=NA, upper=NA, wald.test=NA, p.value=NA))
    }
    
    formula <- as.formula(paste("Surv(OS_time, OS) ~", covariate))
    model <- coxph(formula, data = data)
    s <- summary(model)
    
    beta <- s$coef[1,1]
    HR <- s$coef[1,2]
    lower <- s$conf.int[1,"lower .95"]
    upper <- s$conf.int[1,"upper .95"]
    wald <- s$wald["test"]
    p <- s$wald["pvalue"]
    
    return(c(beta=beta, HR=HR, lower=lower, upper=upper, wald.test=wald, p.value=p))
  }, error=function(e) {
    cat("Erro no gene", covariate, ":", e$message, "\n")
    return(c(beta=NA, HR=NA, lower=NA, upper=NA, wald.test=NA, p.value=NA))
  })
}

covariates <- colnames(final.cox)[-(1:2)]
cat("Analisando", length(covariates), "genes...\n")

univ_results <- lapply(covariates, function(x) safe_cox(x, final.cox))
names(univ_results) <- covariates
res <- as.data.frame(t(as.data.frame(univ_results, check.names=FALSE)))
res <- rownames_to_column(res, var="gene")

# Remover linhas com todos os valores NA
res <- res[!apply(is.na(res[,-1]), 1, all), ]

# Ajustar p-values apenas para valores não-NA
valid_rows <- !is.na(res$p.value)
if(sum(valid_rows) > 0) {
  res$FDR <- NA
  res$FDR[valid_rows] <- p.adjust(res$p.value[valid_rows], method = "fdr")
}

# Mostrar resultados
cat("Genes analisados com sucesso:", sum(valid_rows), "\n")
cat("Genes com p < 0.05:", sum(res$p.value < 0.05, na.rm = TRUE), "\n")

# Genes significativos (CORRIGIDO)
res.final <- subset(res, p.value.pvalue < 0.05 & !is.na(p.value.pvalue))
if(nrow(res.final) == 0) {
  cat("Nenhum gene significativo encontrado!\n")
  cat("P-values mínimos encontrados:\n")
  print(head(res[order(res$p.value, na.last = TRUE), c("gene", "p.value", "HR")]))
  stop("Nenhum gene significativo!")
}

cat("Genes significativos encontrados:", nrow(res.final), "\n")
print(res.final[, c("gene", "HR", "p.value", "FDR")])

